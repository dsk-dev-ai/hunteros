{
  "name": "@hunteros/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared types and interfaces for HunterOS",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
