{
  "name": "@hunteros/environment",
  "version": "0.1.0",
  "private": true,
  "description": "Environment detection for HunterOS — OS, package manager, shell, architecture, CPU, RAM, Docker, Git, Node, Python, Go, Rust",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "default": "./dist/index.js" }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hunteros/shared": "workspace:*",
    "@hunteros/logger": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
