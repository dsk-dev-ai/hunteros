{
  "name": "@hunteros/graph",
  "version": "0.1.0",
  "private": true,
  "description": "Project relationship graph for HunterOS",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config ../../vitest.config.ts"
  },
  "dependencies": {
    "@hunteros/shared": "workspace:*",
    "@hunteros/logger": "workspace:*",
    "@hunteros/ast": "workspace:*",
    "graphology": "^0.25.4"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
