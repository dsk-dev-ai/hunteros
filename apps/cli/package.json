{
  "name": "@hunteros/cli",
  "version": "0.1.0",
  "private": true,
  "description": "HunterOS CLI",
  "license": "MIT",
  "type": "module",
  "bin": {
    "hunteros": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit"
