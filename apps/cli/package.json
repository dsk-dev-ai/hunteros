  "dependencies": {
    "@hunteros/shared": "workspace:*",
    "@hunteros/logger": "workspace:*",
    "@hunteros/config": "workspace:*",
    "@hunteros/cache": "workspace:*",
    "@hunteros/parser": "workspace:*",
    "@hunteros/ast": "workspace:*",
    "@hunteros/graph": "workspace:*",
    "@hunteros/analyzers": "workspace:*",
    "@hunteros/detectors": "workspace:*",
    "@hunteros/framework-detectors": "workspace:*",
    "@hunteros/ai": "workspace:*",
    "@hunteros/reports": "workspace:*",
    "@hunteros/plugins": "workspace:*",
    "@hunteros/scanner": "workspace:*",
    "@hunteros/tools": "workspace:*",
    "@hunteros/environment": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
